<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">

<!--
  Drawing board — 350×350 mm workspace (from seminar spec).

  Board coordinate system (origin = near-left corner, robot side):
    board (  0 mm,   0 mm) = world ( -0.175,  0.000 )
    board (350 mm,   0 mm) = world (  0.175,  0.000 )
    board (  0 mm, 350 mm) = world ( -0.175,  0.350 )

  Board extends in the +y direction from the robot base at world (0, 0, 0).
  Board surface is at z = 0.

  Coordinate markers (r=5 mm cylinders):
    RED    — board origin        (  0,   0) mm = world (-0.175, 0.000)
    ORANGE — board x-axis steps (100, 200, 300, 350) mm
    CYAN   — board y-axis steps (100, 200, 300, 350) mm
    GREEN  — board centre       (175, 175) mm = world (0.000, 0.175)
-->

<xacro:macro name="drawing_board" params="parent">

  <joint name="world_to_drawing_board" type="fixed">
    <parent link="${parent}"/>
    <child link="drawing_board"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="drawing_board">

    <!-- ── board surface (350×350 mm, 3 mm thick) ──────────────────── -->
    <visual>
      <origin xyz="0 0.175 -0.0015" rpy="0 0 0"/>
      <geometry><box size="0.350 0.350 0.003"/></geometry>
      <material name="board_white"><color rgba="0.97 0.97 0.95 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0.175 -0.0015" rpy="0 0 0"/>
      <geometry><box size="0.350 0.350 0.003"/></geometry>
    </collision>

    <!-- ── minor grid lines — 50 mm, light grey ─────────────────────── -->

    <!-- parallel to Y  (board x = 50, 150, 250 mm → world x = -0.125, -0.025, 0.075) -->
    <visual><origin xyz="-0.125 0.175 0.0005" rpy="0 0 0"/><geometry><box size="0.001 0.350 0.001"/></geometry><material name="grid_minor"><color rgba="0.75 0.75 0.75 1.0"/></material></visual>
    <visual><origin xyz="-0.025 0.175 0.0005" rpy="0 0 0"/><geometry><box size="0.001 0.350 0.001"/></geometry><material name="grid_minor"><color rgba="0.75 0.75 0.75 1.0"/></material></visual>
    <visual><origin xyz=" 0.075 0.175 0.0005" rpy="0 0 0"/><geometry><box size="0.001 0.350 0.001"/></geometry><material name="grid_minor"><color rgba="0.75 0.75 0.75 1.0"/></material></visual>

    <!-- parallel to X  (board y = 50, 150, 250 mm → world y = 0.050, 0.150, 0.250) -->
    <visual><origin xyz="0 0.050 0.0005" rpy="0 0 0"/><geometry><box size="0.350 0.001 0.001"/></geometry><material name="grid_minor"><color rgba="0.75 0.75 0.75 1.0"/></material></visual>
    <visual><origin xyz="0 0.150 0.0005" rpy="0 0 0"/><geometry><box size="0.350 0.001 0.001"/></geometry><material name="grid_minor"><color rgba="0.75 0.75 0.75 1.0"/></material></visual>
    <visual><origin xyz="0 0.250 0.0005" rpy="0 0 0"/><geometry><box size="0.350 0.001 0.001"/></geometry><material name="grid_minor"><color rgba="0.75 0.75 0.75 1.0"/></material></visual>

    <!-- ── major grid lines — 100 mm, dark grey ─────────────────────── -->

    <!-- parallel to Y  (board x = 0, 100, 200, 300, 350 mm → world x = -0.175, -0.075, 0.025, 0.125, 0.175) -->
    <visual><origin xyz="-0.175 0.175 0.0007" rpy="0 0 0"/><geometry><box size="0.002 0.350 0.001"/></geometry><material name="grid_major"><color rgba="0.40 0.40 0.40 1.0"/></material></visual>
    <visual><origin xyz="-0.075 0.175 0.0007" rpy="0 0 0"/><geometry><box size="0.002 0.350 0.001"/></geometry><material name="grid_major"><color rgba="0.40 0.40 0.40 1.0"/></material></visual>
    <visual><origin xyz=" 0.025 0.175 0.0007" rpy="0 0 0"/><geometry><box size="0.002 0.350 0.001"/></geometry><material name="grid_major"><color rgba="0.40 0.40 0.40 1.0"/></material></visual>
    <visual><origin xyz=" 0.125 0.175 0.0007" rpy="0 0 0"/><geometry><box size="0.002 0.350 0.001"/></geometry><material name="grid_major"><color rgba="0.40 0.40 0.40 1.0"/></material></visual>
    <visual><origin xyz=" 0.175 0.175 0.0007" rpy="0 0 0"/><geometry><box size="0.002 0.350 0.001"/></geometry><material name="grid_major"><color rgba="0.40 0.40 0.40 1.0"/></material></visual>

    <!-- parallel to X  (board y = 0, 100, 200, 300, 350 mm → world y = 0.000, 0.100, 0.200, 0.300, 0.350) -->
    <visual><origin xyz="0 0.000 0.0007" rpy="0 0 0"/><geometry><box size="0.350 0.002 0.001"/></geometry><material name="grid_major"><color rgba="0.40 0.40 0.40 1.0"/></material></visual>
    <visual><origin xyz="0 0.100 0.0007" rpy="0 0 0"/><geometry><box size="0.350 0.002 0.001"/></geometry><material name="grid_major"><color rgba="0.40 0.40 0.40 1.0"/></material></visual>
    <visual><origin xyz="0 0.200 0.0007" rpy="0 0 0"/><geometry><box size="0.350 0.002 0.001"/></geometry><material name="grid_major"><color rgba="0.40 0.40 0.40 1.0"/></material></visual>
    <visual><origin xyz="0 0.300 0.0007" rpy="0 0 0"/><geometry><box size="0.350 0.002 0.001"/></geometry><material name="grid_major"><color rgba="0.40 0.40 0.40 1.0"/></material></visual>
    <visual><origin xyz="0 0.350 0.0007" rpy="0 0 0"/><geometry><box size="0.350 0.002 0.001"/></geometry><material name="grid_major"><color rgba="0.40 0.40 0.40 1.0"/></material></visual>

    <!-- ── coordinate markers (r=5 mm cylinders, h=5 mm) ────────────── -->

    <!-- RED — board origin (0, 0) mm = world (-0.175, 0.000) -->
    <visual><origin xyz="-0.175 0.000 0.004" rpy="0 0 0"/><geometry><cylinder radius="0.006" length="0.006"/></geometry><material name="board_marker_red"><color rgba="0.90 0.10 0.10 1.0"/></material></visual>

    <!-- ORANGE — x-axis steps: board (100,0) (200,0) (300,0) (350,0) mm -->
    <visual><origin xyz="-0.075 0.000 0.004" rpy="0 0 0"/><geometry><cylinder radius="0.005" length="0.005"/></geometry><material name="board_marker_orange"><color rgba="0.95 0.55 0.05 1.0"/></material></visual>
    <visual><origin xyz=" 0.025 0.000 0.004" rpy="0 0 0"/><geometry><cylinder radius="0.005" length="0.005"/></geometry><material name="board_marker_orange"><color rgba="0.95 0.55 0.05 1.0"/></material></visual>
    <visual><origin xyz=" 0.125 0.000 0.004" rpy="0 0 0"/><geometry><cylinder radius="0.005" length="0.005"/></geometry><material name="board_marker_orange"><color rgba="0.95 0.55 0.05 1.0"/></material></visual>
    <visual><origin xyz=" 0.175 0.000 0.004" rpy="0 0 0"/><geometry><cylinder radius="0.005" length="0.005"/></geometry><material name="board_marker_orange"><color rgba="0.95 0.55 0.05 1.0"/></material></visual>

    <!-- CYAN — y-axis steps: board (0,100) (0,200) (0,300) (0,350) mm -->
    <visual><origin xyz="-0.175 0.100 0.004" rpy="0 0 0"/><geometry><cylinder radius="0.005" length="0.005"/></geometry><material name="board_marker_cyan"><color rgba="0.05 0.70 0.90 1.0"/></material></visual>
    <visual><origin xyz="-0.175 0.200 0.004" rpy="0 0 0"/><geometry><cylinder radius="0.005" length="0.005"/></geometry><material name="board_marker_cyan"><color rgba="0.05 0.70 0.90 1.0"/></material></visual>
    <visual><origin xyz="-0.175 0.300 0.004" rpy="0 0 0"/><geometry><cylinder radius="0.005" length="0.005"/></geometry><material name="board_marker_cyan"><color rgba="0.05 0.70 0.90 1.0"/></material></visual>
    <visual><origin xyz="-0.175 0.350 0.004" rpy="0 0 0"/><geometry><cylinder radius="0.005" length="0.005"/></geometry><material name="board_marker_cyan"><color rgba="0.05 0.70 0.90 1.0"/></material></visual>

    <!-- GREEN — board centre (175, 175) mm = world (0.000, 0.175) -->
    <visual><origin xyz="0.000 0.175 0.005" rpy="0 0 0"/><geometry><cylinder radius="0.007" length="0.008"/></geometry><material name="board_marker_green"><color rgba="0.10 0.85 0.20 1.0"/></material></visual>

    <inertial>
      <origin xyz="0 0.175 -0.0015" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.005" iyy="0.005" izz="0.010" ixy="0" iyz="0" ixz="0"/>
    </inertial>

  </link>

</xacro:macro>
</robot>
