<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">

<xacro:macro name="prarob_manipulator" params="parent *origin">
  <joint name="origin_to_link1" type="fixed">
    <xacro:insert_block name="origin" />
    <parent link="${parent}" />
    <child link="link1" />
    <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
    <axis xyz="0 0 1" />
  </joint>

  <!-- Link 1 - base column -->
  <link name="link1">
    <visual>
      <origin xyz="0 0 0.5" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 1.0"/>
      </geometry>
      <material name="link1_mat">
        <color rgba="0.054901960784313725 0.054901960784313725 0.06274509803921569 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.5" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 1.0"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.5" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.042" ixy="0" ixz="0"
               iyy="0.042" iyz="0"
               izz="0.0002"/>
    </inertial>
  </link>

  <!-- Joint 1 — base yaw -->
  <joint name="joint1" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0.0 0.0 1.0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit velocity="10.0" effort="1" lower="-2.82743338823" upper="2.82743338823"/>
  </joint>

  <!-- Link 2 — upper arm -->
  <link name="link2">
    <visual>
      <origin xyz="0 0 0.3" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.6"/>
      </geometry>
      <material name="link2_mat">
        <color rgba="0.0 0.8 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.3" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.6"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.3" rpy="0 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.009" ixy="0" ixz="0"
               iyy="0.009" iyz="0"
               izz="0.0001"/>
    </inertial>
  </link>

  <!-- Joint 2 — shoulder pitch -->
  <joint name="joint2" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0.0 0.0 0.60" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit velocity="10.0" effort="1" lower="-2.82743338823" upper="2.82743338823"/>
  </joint>

  <!-- Link 3 — forearm -->
  <link name="link3">
    <visual>
      <origin xyz="0.15 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.3 0.05 0.05"/>
      </geometry>
      <material name="link3_mat">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.15 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.3 0.05 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.15 0 0" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.00003" ixy="0" ixz="0"
               iyy="0.00115" iyz="0"
               izz="0.00115"/>
    </inertial>
  </link>

  <!-- Joint 3 — wrist -->
  <joint name="joint3" type="revolute">
    <parent link="link3"/>
    <child link="link_tool"/>
    <origin xyz="0.3 0.0 0.0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit velocity="10.0" effort="1" lower="-2.82743338823" upper="2.82743338823"/>
  </joint>

  <!-- link_tool — end effector -->
  <link name="link_tool">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.08 0.08"/>
      </geometry>
      <material name="tool_mat">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.08 0.08"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00003" ixy="0" ixz="0"
               iyy="0.00003" iyz="0"
               izz="0.00003"/>
    </inertial>
  </link>

</xacro:macro>
</robot>
